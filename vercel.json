{
  "version": 2,
  "installCommand": "npm install --prefix task-management-app/client",
  "buildCommand": "npm run build --prefix task-management-app/client",
  "outputDirectory": "task-management-app/client/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "experimentalServices": {
    "task-management-api": {
      "type": "web",
      "root": "task-management-app/server",
      "entrypoint": "server.js",
      "routePrefix": "/",
      "buildCommand": "npm install"
    }
  }
}
